# Compiled Object files
*.slo
*.lo
*.o
*.obj
*.dat
*.bin
*.depend
*.layout
*.xyz

# Precompiled Headers
*.gch
*.pch

# Compiled Dynamic libraries
*.so
*.dylib
*.dll

# Fortran module files
*.mod

# Compiled Static libraries
*.lai
*.la
*.a
*.lib

# Executables
*.exe
*.out
*.app

# Archives
*.zip

# Local experiments / scratch verification (not part of the project)
experiments/
gui/

# Regression tests: build artifacts are ignored, the small committed grid is
# exempt from the global *.bin ignore above
tests/build/
!tests/data/*.bin

# Papers and documents
*.docx

# Atomistic molecule models are sources, exempt from the global *.xyz ignore
# (that rule targets the trajectory outputs)
!models/*.xyz
