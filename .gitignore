# Compiled Object files
*.slo
*.lo
*.o
*.obj
*.dat
*.bin
*.depend
*.layout
*.xyz

# Precompiled Headers
*.gch
*.pch

# Compiled Dynamic libraries
*.so
*.dylib
*.dll

# Fortran module files
*.mod

# Compiled Static libraries
*.lai
*.la
*.a
*.lib

# Executables
*.exe
*.out
*.app

# Archives
*.zip

run.log

# Local experiments / scratch verification (not part of the project)
experiments/

# Regression tests: build artifacts are ignored, the small committed grid is
# exempt from the global *.bin ignore above
tests/build/
!tests/data/*.bin

# Papers and documents
*.docx

# GUI: Python virtual environment and caches
gui/.venv/
__pycache__/
*.pyc
*.egg-info/

# GUI: PyInstaller build output (see gui/studio.spec)
gui/build/
gui/dist/

# Release bundles assembled by tools/make_bundle.py
dist/

# Atomistic molecule models are sources, exempt from the global *.xyz ignore
# (that rule targets the trajectory and run outputs). This covers the sample
# models and each sample project's own molecule files.
!samples/models/*.xyz
!samples/projects/**/molecules/*.xyz
